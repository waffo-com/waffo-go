# E2E Test Configuration
# Copy this file to application-test.yml and fill in your credentials
# IMPORTANT: DO NOT commit application-test.yml to git!

# Waffo API credentials (get from Waffo Dashboard)
api-key: your-sandbox-api-key
private-key: your-base64-encoded-private-key
waffo-public-key: waffo-sandbox-public-key
merchant-id: your-merchant-id
environment: SANDBOX
